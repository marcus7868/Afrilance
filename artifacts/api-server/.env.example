# ── API Server environment variables ────────────────────────────────────────
# Copy this file to .env and fill in the values.

# PostgreSQL connection string (from Neon, Supabase, or local Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Clerk secret key (from https://dashboard.clerk.com → API Keys)
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Paystack keys (from https://dashboard.paystack.com → Settings → API Keys)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server port (defaults to 8080)
PORT=8080

# Log level (debug | info | warn | error)
LOG_LEVEL=info

# Node environment
NODE_ENV=development
