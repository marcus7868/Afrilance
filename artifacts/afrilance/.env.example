# ── Frontend environment variables ──────────────────────────────────────────
# Copy this file to .env and fill in the values.

# Clerk publishable key (from https://dashboard.clerk.com → API Keys)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Only needed when the API server is on a different domain (e.g. Railway).
# Leave blank when running locally (the Vite dev proxy handles it).
VITE_API_BASE_URL=

# Vite dev server port (optional, defaults to 5173)
PORT=5173

# Base path for the app (optional, defaults to /)
BASE_PATH=/
